# Supabase project connection keys
# Copy this file to '.env' and fill in your Supabase project keys to switch to the live database
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Razorpay payment gateway - Frontend (public)
# Get your Key ID from: https://dashboard.razorpay.com/app/keys
# Use the TEST key (rzp_test_...) for development, LIVE key (rzp_live_...) for production
VITE_RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID_HERE

# Razorpay payment gateway - Backend (server-side only)
# NEVER use VITE_ prefix for these - they are server-only secrets
# Get your Key Secret from: https://dashboard.razorpay.com/app/keys
# These must be added in Vercel dashboard under Settings → Environment Variables
# WARNING: Never commit these to git, never expose in frontend code
RAZORPAY_KEY_ID=rzp_test_or_live_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret_here
